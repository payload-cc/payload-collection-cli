{
  "name": "@payload-cc/payload-collection-cli",
  "version": "1.2.0",
  "description": "Functional CLI for Payload 3.0 collection management",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/payload-cc/payload-collection-cli.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "payload-collection-cli": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format cjs,esm --dts --clean --shims && chmod +x dist/bin.js",
    "release": "pnpm build && pnpm publish --access public",
    "test": "vitest run tests/*",
    "test:e2e": "vitest run e2e-tests/scenarios/ --no-file-parallelism"
  },
  "keywords": [
    "payload",
    "payload-cms",
    "cli"
  ],
  "author": "",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.32.1",
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "payload": "^3.79.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}